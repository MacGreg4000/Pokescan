# pokemontcg.io API key (free tier: 1000 req/day without key, 20k with key)
# Get yours at: https://dev.pokemontcg.io/
POKEMONTCG_API_KEY=your_api_key_here

# Ollama service URL — pointer vers l'instance Ollama (locale ou réseau)
# Exemple réseau local: http://192.168.0.77:11434
# Exemple local:        http://localhost:11434
OLLAMA_URL=http://192.168.0.77:11434

# Ollama model — doit être déjà présent dans votre instance (ollama list)
# Recommandé: qwen3:8b (5.2 GB, rapide, excellent JSON)
# Alternatives: qwen3.5:latest | gemma4:e4b | qwen2.5-coder:14b | gemma4:26b
OLLAMA_MODEL=qwen3:8b

# Ollama vision model — pour le scan par photo
# Recommandé: qwen3-vl:8b
OLLAMA_VISION_MODEL=qwen3-vl:8b

# SQLite database file path
# Local dev: leave empty → defaults to ./pokescan.db
# Docker:    /data/pokescan.db (set automatically by docker-compose)
DATABASE_PATH=./pokescan.db

# Admin authentication
# Mot de passe pour se connecter à /admin/login
ADMIN_PASSWORD=changez_ce_mot_de_passe

# Token de session (générer avec: openssl rand -hex 32)
ADMIN_SESSION_TOKEN=changez_ce_token_avec_openssl_rand_hex_32
